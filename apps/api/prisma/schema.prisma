// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  discordId    String   @unique
  username     String
  icFirstName  String? // IC Vorname
  icLastName   String? // IC Nachname
  avatarUrl    String?
  email        String?
  gender       Gender?  @default(MALE) // Geschlecht für Kleidungszuweisung
  role         Role     @default(SOLDADO)
  allRoles     Json     @default("[]") // Alle System-Rollen des Users (JSON array)
  discordRoles Json     @default("[]") // Discord Rollen-IDs (JSON array)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  actions                          ActionLog[]
  moneyTxCreated                   MoneyTransaction[]             @relation("tx_created_by")
  moneyTxApproved                  MoneyTransaction[]             @relation("tx_approved_by")
  stockMovements                   StockMovement[]                @relation("movement_created_by")
  stockMovementsApproved           StockMovement[]                @relation("movement_approved_by")
  packageDeposits                  PackageDeposit[]               @relation("deposit_created_by")
  packageConfirmations             PackageDeposit[]               @relation("deposit_confirmed_by")
  packageRejections                PackageDeposit[]               @relation("deposit_rejected_by")
  weeklyDeliveries                 WeeklyDelivery[]               @relation("delivery_created_by")
  weeklyDeliveryConfirmations      WeeklyDelivery[]               @relation("delivery_confirmed_by")
  sanctionsCreated                 Sanction[]                     @relation("sanction_created_by")
  sanctionsReceived                Sanction[]                     @relation("sanction_received_by")
  exclusionsReceived               WeeklyDeliveryExclusion[]      @relation("exclusion_user")
  exclusionsCreated                WeeklyDeliveryExclusion[]      @relation("exclusion_created_by")
  archivesCreated                  WeeklyDeliveryArchive[]        @relation("archive_created_by")
  aufstellungenCreated             Aufstellung[]                  @relation("aufstellung_created_by")
  aufstellungResponses             AufstellungResponse[]          @relation("aufstellung_responses")
  aufstellungExclusionsReceived    AufstellungExclusion[]         @relation("aufstellung_exclusion_user")
  aufstellungExclusionsCreated     AufstellungExclusion[]         @relation("aufstellung_exclusion_created_by")
  abmeldungenCreated               Abmeldung[]                    @relation("abmeldung_user")
  familiensammelnParticipations    FamiliensammelnParticipation[] @relation("familiensammeln_participations")
  organigrammAssignments           OrganigrammAssignment[]        @relation("organigramm_assignments")
  processors                       FamiliensammelnProcessor[]     @relation("processor_user")
  processorsCompleted              FamiliensammelnProcessor[]     @relation("processor_completed_by")
  memberFile                       MemberFile?                    @relation("member_files")
  fileEntriesCreated               MemberFileEntry[]              @relation("file_entries_created")
  sicarioAufstellungenCreated      SicarioAufstellung[]           @relation("sicario_aufstellung_created_by")
  sicarioAufstellungResponses      SicarioAufstellungResponse[]   @relation("sicario_aufstellung_responses")
  mapAnnotationsCreated            MapAnnotation[]                @relation("map_annotation_created_by")
  mapAreasCreated                  MapArea[]                      @relation("map_area_created_by")
  familyContactsOutdatedMarked     FamilyContact[]                @relation("family_contact_outdated_by")
  dailyAttendanceMarked            DailyAttendance[]              @relation("attendance_marked_by")
  dailyAttendanceReceived          DailyAttendance[]              @relation("attendance_user")
  attendancePermissionsGranted     AttendancePermission[]         @relation("attendance_permission_granted_by")
  attendancePermissionsReceived    AttendancePermission[]         @relation("attendance_permission_user")
  listPermissionsGranted           ListPermission[]               @relation("list_permission_granted_by")
  listPermissionsReceived          ListPermission[]               @relation("list_permission_user")
  mapPermissionsGranted            MapPermission[]                @relation("map_permission_granted_by")
  mapPermissionsReceived           MapPermission[]                @relation("map_permission_user")
  mapSuggestionsCreated            MapSuggestion[]                @relation("map_suggestion_created_by")
  mapSuggestionsReviewed           MapSuggestion[]                @relation("map_suggestion_reviewed_by")
  // Partner System
  isPartner                        Boolean                        @default(false) // Kennzeichnet Partner-User
  partnerCanViewContacts           Boolean                        @default(false) // Partner kann Kontaktdetails sehen
  partnerRequestsReviewed          PartnerAccessRequest[]         @relation("partner_request_reviewed_by")
  partnerPermissionsGranted        PartnerManagementPermission[]  @relation("partner_permission_granted_by")
  partnerPermissionsReceived       PartnerManagementPermission[]  @relation("partner_permission_user")
  partnerFamilySuggestionsCreated  PartnerFamilySuggestion[]      @relation("partner_family_suggestion_created_by")
  partnerFamilySuggestionsReviewed PartnerFamilySuggestion[]      @relation("partner_family_suggestion_reviewed_by")
  // Tafelrunde System
  tafelrundenCreated               Tafelrunde[]                   @relation("tafelrunde_created_by")
  tafelrundeFamiliesUpdated        TafelrundeFamily[]             @relation("tafelrunde_family_updated_by")
  tafelrundePermissionsGranted     TafelrundePermission[]         @relation("tafelrunde_permission_granted_by")
  tafelrundePermissionsReceived    TafelrundePermission[]         @relation("tafelrunde_permission_user")
  // Taxi System
  isTaxi                           Boolean                        @default(false) // Kennzeichnet Taxi-User
  isTaxiLead                       Boolean                        @default(false) // Taxi-Leitungsebene (Master Key)
  taxiKeysCreated                  TaxiKey[]                      @relation("taxi_key_created_by")
  taxiKeysUsed                     TaxiKey[]                      @relation("taxi_key_used_by")
  taxiAssignmentsAssigned          TaxiAssignment[]               @relation("taxi_assignment_driver")
  taxiAssignmentsCreated           TaxiAssignment[]               @relation("taxi_assignment_created_by")
  // Equipment Management
  equipmentWeapons                 EquipmentWeapon[]              @relation("equipment_weapons")
  equipmentWeaponsCreated          EquipmentWeapon[]              @relation("equipment_weapon_created_by")
  equipmentVests                   EquipmentVest[]                @relation("equipment_vests")
  equipmentVestsCreated            EquipmentVest[]                @relation("equipment_vest_created_by")
  equipmentAmmo                    EquipmentAmmo[]                @relation("equipment_ammo")
  equipmentAmmoCreated             EquipmentAmmo[]                @relation("equipment_ammo_created_by")

  @@map("users")
}

enum Role {
  // Alte Rollen (temporär für Migration)
  ADMIN
  QUARTIERMEISTER
  MITGLIED
  GAST
  // Leaderschaft (automatisch synchronisiert)
  EL_PATRON // 👑 - El Patrón
  DON_CAPITAN // ⚔️ - Don - El Capitán
  DON_COMANDANTE // 🛡️ - Don - El Comandante
  EL_MANO_DERECHA // 🤝 - El Mano Derecha
  // Normale Ränge (1-9)
  EL_CUSTODIO // 🔒 - Rang 9 - Sicherheitsbegleitung / Wachposten
  EL_MENTOR // 📚 - Rang 8 - Ausbilder der Neulinge
  EL_ENCARGADO // 🧰 - Rang 7 - Zuständiger / Koordinator
  EL_TENIENTE // ⭐ - Rang 6 - Unteroffizier / Bereichsverantwortlicher
  SOLDADO // 🧭 - Rang 5 - Vollwertiger Soldat (Kern der Truppe)
  EL_PREFECTO // 🐍 - Rang 4 - Kontrollinstanz / Operationsaufsicht
  EL_CONFIDENTE // 🫢 - Rang 3 - Vertrauensperson der Führung
  EL_PROTECTOR // 🐢 - Rang 2 - Schutz der Führung
  EL_NOVATO // 🌱 - Rang 1 - Neuling / Probezeit
  // Funktionsrollen (zusätzliche Rollen neben Rang)
  CONSEJERO // 🧘 - Consejero/a (Berater)
  RUTAS // 🚛 - Rutas (Routenverwaltung)
  LOGISTICA // 📦 - Logística (Lagerverwaltung)
  INTELIGENCIA // 🧠 - Inteligencia (Nachrichtendienst)
  FORMACION // 🎓 - Formación (Ausbildung)
  SICARIO // 🔫 - Sicario (Spezialkräfte)
  CONTACTO // 📞 - Contacto (Kontaktperson)
  // Legacy Rollen (deprecated)
  ROUTENVERWALTUNG // Alte Routenverwaltung
  FUTURO // Anwärter, niedrigste Rolle, nur lesen
  // Partner (externe Benutzer)
  PARTNER // 🤝 - Partner (eingeschränkter Zugriff auf Karte & Listen)
  // Taxi System
  TAXI // 🚕 - Taxi-Fahrer (kann zugewiesene Familien sehen)
  TAXI_LEAD // 🚖 - Taxi-Leitung (kann Fahrer zuweisen, Master Key)
}

model Module {
  id        String   @id @default(cuid())
  key       String   @unique // "lager", "kasse", future modules
  name      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("modules")
}

model ItemCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  items     Item[]
  createdAt DateTime @default(now())

  @@map("item_categories")
}

model Item {
  id            String       @id @default(cuid())
  name          String
  sku           String?      @unique
  categoryId    String
  category      ItemCategory @relation(fields: [categoryId], references: [id])
  minStock      Int          @default(0)
  currentStock  Int          @default(0)
  reservedStock Int          @default(0)
  isLocked      Boolean      @default(false)
  tags          Json         @default("[]") // Tags als JSON array (MySQL hat keine nativen Arrays)
  location      String? // Regal/Standort
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relations
  stockEntries StockMovement[]

  @@map("items")
}

enum MovementType {
  IN
  OUT
  ADJUST
  RESERVE
  RELEASE
}

enum MovementStatus {
  PENDING
  APPROVED
  REJECTED
}

model StockMovement {
  id              String         @id @default(cuid())
  itemId          String
  item            Item           @relation(fields: [itemId], references: [id])
  type            MovementType
  quantity        Int
  previousStock   Int
  newStock        Int
  note            String?
  reference       String? // Auftrag/Person/Event
  batchNumber     String? // für Serien/Batches
  status          MovementStatus @default(PENDING)
  approvedById    String?
  approvedBy      User?          @relation("movement_approved_by", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectionReason String?
  createdById     String
  createdBy       User           @relation("movement_created_by", fields: [createdById], references: [id])
  createdAt       DateTime       @default(now())

  @@map("stock_movements")
}

model MoneyTransaction {
  id           String            @id @default(cuid())
  kind         MoneyKind
  amount       Int // in Einheiten (1 = 1$ Schwarz)
  category     String?
  note         String?
  reference    String? // Auftrag/Person
  status       TransactionStatus @default(PENDING)
  approvedById String?
  createdById  String
  createdBy    User              @relation("tx_created_by", fields: [createdById], references: [id])
  approvedBy   User?             @relation("tx_approved_by", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  createdAt    DateTime          @default(now())

  @@map("money_transactions")
}

enum MoneyKind {
  EINZAHLUNG
  AUSZAHLUNG
  TRANSFER
  KORREKTUR
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

model ActionLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String // e.g. "ITEM_CREATE", "MOVE_OUT", "MONEY_TX"
  entity    String // "Item", "StockMovement", "MoneyTransaction"
  entityId  String
  meta      Json
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@map("action_logs")
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  type      String   @default("string") // "string", "number", "boolean", "json"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// Aktensystem
model MemberFile {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation("member_files", fields: [userId], references: [id])
  lastUprankDate DateTime? // Datum des letzten Upranks
  isArchived     Boolean   @default(false) // Archiviert wenn Blood Out
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  entries MemberFileEntry[]

  @@map("member_files")
}

model MemberFileEntry {
  id          String        @id @default(cuid())
  fileId      String
  file        MemberFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)
  type        FileEntryType // POSITIVE, NEGATIVE, NEUTRAL
  content     String        @db.Text
  createdById String
  createdBy   User          @relation("file_entries_created", fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("member_file_entries")
}

enum FileEntryType {
  POSITIVE
  NEGATIVE
  NEUTRAL
}

model CasaImage {
  id        String   @id @default(cuid())
  filename  String
  path      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("casa_images")
}

// Package-Deposit System (früher Kokain)
model PackageDeposit {
  id                     String           @id @default(cuid())
  userId                 String
  user                   User             @relation("deposit_created_by", fields: [userId], references: [id])
  packages               Int // Anzahl Pakete
  status                 DepositStatus    @default(PENDING)
  confirmedById          String?
  confirmedBy            User?            @relation("deposit_confirmed_by", fields: [confirmedById], references: [id])
  confirmedAt            DateTime?
  rejectedById           String?
  rejectedBy             User?            @relation("deposit_rejected_by", fields: [rejectedById], references: [id])
  rejectedAt             DateTime?
  rejectionReason        String?
  note                   String?
  uebergabeId            String? // Referenz zur Übergabe-Session
  uebergabe              PackageHandover? @relation(fields: [uebergabeId], references: [id])
  // Wochenabgabe Integration
  weeklyDeliveryId       String? // Referenz zur Wochenabgabe
  weeklyDelivery         WeeklyDelivery?  @relation(fields: [weeklyDeliveryId], references: [id])
  weeklyDeliveryPackages Int? // Pakete die für Wochenabgabe verwendet wurden
  payoutPackages         Int? // Pakete die als Auszahlung verwendet wurden
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  @@map("package_deposits")
}

enum DepositStatus {
  PENDING
  CONFIRMED
  REJECTED
}

// Übergabe-Sessions für Archivierung
model PackageHandover {
  id            String    @id @default(cuid())
  name          String // z.B. "Übergabe Dezember 2024"
  totalPackages Int
  totalValue    Int // Gesamtwert in Schwarzgeld
  isActive      Boolean   @default(true)
  archivedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  deposits PackageDeposit[]

  @@map("package_handovers")
}

model DiscordRoleMapping {
  id            String   @id @default(cuid())
  discordRoleId String   @unique // Discord Rollen-ID
  systemRole    Role // System-Rolle
  name          String // Name der Discord-Rolle
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("discord_role_mappings")
}

// Wochenabgabe System
model WeeklyDelivery {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation("delivery_created_by", fields: [userId], references: [id])
  weekStart       DateTime // Start der Woche (Montag)
  weekEnd         DateTime // Ende der Woche (Sonntag)
  packages        Int                  @default(300) // Standard: 300 Pakete
  paidAmount      Int? // Bezahlte Menge in Paketen
  paidMoney       Int? // Bezahlte Menge in Schwarzgeld
  status          WeeklyDeliveryStatus @default(PENDING)
  confirmedById   String?
  confirmedBy     User?                @relation("delivery_confirmed_by", fields: [confirmedById], references: [id])
  confirmedAt     DateTime?
  note            String?
  isPrepaid       Boolean              @default(false) // Vorauszahlung für mehrere Wochen
  prepaidWeeks    Int? // Anzahl der vorausbezahlten Wochen
  isAbgemeldet    Boolean              @default(false) // Persistent: User war >2 Tage abgemeldet
  abgemeldeteDays Int? // Anzahl der abgemeldeten Tage während dieser Woche
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  // Relations
  packageDeposits PackageDeposit[]

  @@map("weekly_deliveries")
}

enum WeeklyDeliveryStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
}

// Wochenabgabe Ausschlüsse
model WeeklyDeliveryExclusion {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("exclusion_user", fields: [userId], references: [id])
  reason      String
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdById String
  createdBy   User      @relation("exclusion_created_by", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("weekly_delivery_exclusions")
}

model WeeklyDeliveryArchive {
  id                String   @id @default(cuid())
  weekStart         DateTime
  weekEnd           DateTime
  archiveName       String
  totalDeliveries   Int
  paidDeliveries    Int
  overdueDeliveries Int
  pendingDeliveries Int
  totalPackages     Int
  paidPackages      Int
  totalMoney        Int
  deliveryData      Json // Vollständige Delivery-Daten
  archivedById      String
  archivedBy        User     @relation("archive_created_by", fields: [archivedById], references: [id])
  createdAt         DateTime @default(now())

  @@map("weekly_delivery_archives")
}

// Sanktionssystem
model Sanction {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation("sanction_received_by", fields: [userId], references: [id])
  category    SanctionCategory
  level       Int              @default(1) // 1-4, Level bestimmt Strafe
  description String
  amount      Int? // Geldstrafe in Schwarzgeld
  penalty     String? // Spezielle Strafe (z.B. "LaSanta Calavera Brücke 1x")
  status      SanctionStatus   @default(ACTIVE)
  createdById String
  createdBy   User             @relation("sanction_created_by", fields: [createdById], references: [id])
  paidAt      DateTime?
  expiresAt   DateTime? // Für automatische Bereinigung nach 4 Wochen
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("sanctions")
}

enum SanctionCategory {
  ABMELDUNG
  RESPEKTVERHALTEN
  FUNKCHECK
  REAKTIONSPFLICHT
  NICHT_BEZAHLT
  NICHT_BEZAHLT_48H
  // Neue Sanktionen
  RESPEKTLOS_ZIVILISTEN
  RESPEKTLOS_FAMILIE
  TOETUNG_FAMILIENMITGLIEDER
  SEXUELLE_BELAESTIGUNG
  UNNOETIGES_BOXEN_SCHIESSEN
  MISSACHTUNG_ANWEISUNGEN
  FEHLEN_AUFSTELLUNG
  NICHT_ANMELDEN_FUNKCHECK
  KLEIDERORDNUNG
  MUNITIONSVERSCHWENDUNG
  CASA_OHNE_ANKUENDIGUNG
  FUNKPFLICHT_MISSACHTUNG
  FUNKDISZIPLIN_MISSACHTUNG
  WOCHENABGABE_NICHT_ENTRICHTET // Verpflichtet zur Wochenabgabe, aber nicht abgegeben
}

enum SanctionStatus {
  ACTIVE
  PAID
  EXPIRED
  CANCELLED
}

// Aufstellungssystem
model Aufstellung {
  id          String   @id @default(cuid())
  createdById String
  createdBy   User     @relation("aufstellung_created_by", fields: [createdById], references: [id])
  date        DateTime // Datum und Uhrzeit der Aufstellung
  reason      String // Grund/Location der Aufstellung
  deadline    DateTime // Deadline für Reaktionen (= date)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  responses AufstellungResponse[]

  @@map("aufstellungen")
}

// Aufstellung-Ausschlüsse (wie Wochenabgabe-Ausschlüsse)
model AufstellungExclusion {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("aufstellung_exclusion_user", fields: [userId], references: [id])
  reason      String
  startDate   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdById String
  createdBy   User      @relation("aufstellung_exclusion_created_by", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("aufstellung_exclusions")
}

model AufstellungResponse {
  id            String                    @id @default(cuid())
  aufstellungId String
  aufstellung   Aufstellung               @relation(fields: [aufstellungId], references: [id], onDelete: Cascade)
  userId        String
  user          User                      @relation("aufstellung_responses", fields: [userId], references: [id], onDelete: Cascade)
  status        AufstellungResponseStatus
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt

  @@unique([aufstellungId, userId])
  @@map("aufstellung_responses")
}

enum AufstellungResponseStatus {
  COMING // Kommt
  COMING_LATE // Kommt später
  NOT_COMING // Kommt nicht
  UNSURE // Unsicher
}

// Abmeldungssystem
model Abmeldung {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("abmeldung_user", fields: [userId], references: [id])
  startDate DateTime // Start der Abmeldung
  endDate   DateTime // Ende der Abmeldung
  reason    String? // Grund der Abmeldung (optional)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("abmeldungen")
}

// BloodList System - Mitgliederverwaltung
model BloodRecord {
  id                String      @id @default(cuid())
  vorname           String
  nachname          String
  telefon           Int
  steam             String
  bloodinDurch      String // Wer hat Blood In durchgeführt
  bloodinTimestamp  DateTime    @default(now())
  status            BloodStatus @default(ACTIVE)
  bloodoutTimestamp DateTime?
  bloodoutDurch     String?
  bloodoutGrund     String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@unique([telefon, status]) // Telefon muss unique sein für ACTIVE Status
  @@map("blood_records")
}

enum BloodStatus {
  ACTIVE
  BLOODOUT
}

// Familiensammeln System
model FamiliensammelnWeek {
  id        String   @id @default(cuid())
  weekStart DateTime // Montag
  weekEnd   DateTime // Samstag (6 Tage)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  participations FamiliensammelnParticipation[]
  processors     FamiliensammelnProcessor[]

  @@unique([weekStart])
  @@map("familiensammeln_weeks")
}

model FamiliensammelnParticipation {
  id        String              @id @default(cuid())
  weekId    String
  week      FamiliensammelnWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation("familiensammeln_participations", fields: [userId], references: [id])
  date      DateTime // Datum der Teilnahme
  tourCount Int                 @default(1) // Anzahl der Touren an diesem Tag
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@unique([weekId, userId, date]) // User kann nur 1x pro Tag teilnehmen
  @@map("familiensammeln_participations")
}

// Organigramm-Rollenzuweisungen
model OrganigrammAssignment {
  id        String   @id @default(cuid())
  roleId    String // z.B. "patron", "capitan", "comandante", etc.
  userId    String
  user      User     @relation("organigramm_assignments", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, userId]) // Ein User kann nur einmal pro Rolle zugewiesen werden
  @@map("organigramm_assignments")
}

// Familiensammeln Verarbeiter (Processor Tracking)
model FamiliensammelnProcessor {
  id              String              @id @default(cuid())
  weekId          String
  week            FamiliensammelnWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  userId          String
  user            User                @relation("processor_user", fields: [userId], references: [id], onDelete: Cascade)
  startedAt       DateTime            @default(now()) // Wann wurde der Verarbeiter gestartet
  finishesAt      DateTime // Wann ist der Verarbeiter fertig (startedAt + 5 Stunden)
  capacity        Int                 @default(3000) // Kapazität des Verarbeiters
  processingRate  Int                 @default(10) // Wie viele Stück pro Minute verarbeitet werden
  status          ProcessorStatus     @default(PROCESSING)
