# Production Environment Variables
# Kopiere diese Datei zu .env und fülle die Werte aus

# Database
POSTGRES_PASSWORD="your-secure-database-password"

# JWT Secrets (VERWENDE STARK PASSWÖRTER!)
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars"

# Discord OAuth
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"

# Discord Bot (für Rollen-Synchronisation)
DISCORD_BOT_TOKEN="your_discord_bot_token"
DISCORD_GUILD_ID="your_discord_server_id"

# Discord Webhooks
DISCORD_WEBHOOK_URL="your_aufstellung_webhook_url_for_channel_1431388063195594981"
DISCORD_ABMELDUNG_WEBHOOK_URL="your_abmeldung_webhook_url_for_channel_1431388063195594983"

# URLs (für lsc-nc.de mit SSL)
FRONTEND_URL="https://lsc-nc.de"
API_BASE_URL="https://lsc-nc.de"

# Optional: SSL Zertifikate
# SSL_CERT_PATH="/path/to/cert.pem"
# SSL_KEY_PATH="/path/to/private.key"
